{
  "name": "food-ordering-backend",
  "version": "1.0.0",
  "description": "Food Ordering System Backend with RBAC",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:migrate": "node src/config/migrate.js",
    "db:seed": "node src/config/seed.js",
    "release": "npm run db:migrate",
    "build-client": "cd ../frontend && npm ci && npm run build",
    "build": "npm run build-client && npm run db:migrate && npm run db:seed",
    "postinstall": "npm run build-client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
