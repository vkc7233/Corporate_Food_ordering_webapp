# Application settings
PORT=5000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345

# Database connection (use DATABASE_URL for cloud, or individual params for local)
DATABASE_URL=postgresql://postgres:password@localhost:5432/food_ordering

# Optional: Individual database parameters (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=food_ordering
DB_USER=postgres
DB_PASSWORD=password

# CORS settings - adjust for local development
FRONTEND_URL=http://localhost:5173