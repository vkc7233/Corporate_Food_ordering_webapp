# ================================
# FoodFlow Backend Configuration
# ================================

# Application Environment
NODE_ENV=development
PORT=5000

# ================================
# JWT Configuration
# ================================
# IMPORTANT: Change this to a strong, unique string in production!
# Minimum 10 characters recommended. Used for signing authentication tokens.
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345

# ================================
# Database Configuration
# ================================

# Option 1: Connection String (recommended for production/cloud deployments)
# Uncomment and use DATABASE_URL if connecting to a cloud database (Render, Heroku, etc.)
# DATABASE_URL=postgresql://username:password@host:port/database_name?sslmode=require

# Option 2: Individual Parameters (recommended for local development)
# Used only if DATABASE_URL is not set
DB_HOST=localhost
DB_PORT=5432
DB_NAME=food_ordering
DB_USER=postgres
DB_PASSWORD=password

# ================================
# CORS Configuration
# ================================
# The frontend URL that is allowed to make requests to this API
# For local development with Vite dev server:
FRONTEND_URL=http://localhost:5173

# For production, use your deployed frontend URL:
# FRONTEND_URL=https://your-frontend-domain.com

# ================================
# Setup Instructions
# ================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Update the DATABASE_URL or individual DB credentials for your setup
# 3. Change JWT_SECRET to a strong, unique value
# 4. Run migrations: npm run db:migrate
# 5. Seed demo data: npm run db:seed
# 6. Start the server: npm run dev (or npm start for production)

